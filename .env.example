# Server
PORT=3000
NODE_ENV=development

# SQLite database path
SQLITE_PATH=./data/medications.db

# IBM WatsonX AI
WATSONX_API_KEY=your_ibm_api_key
WATSONX_PROJECT_ID=your_watsonx_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=meta-llama/llama-3-1-70b-instruct

# Web Push (VAPID) — generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_CONTACT=mailto:your@email.com

# Cron expression for weekly AI analysis (default: Sunday 02:00)
AI_WEEKLY_CRON=0 2 * * 0
